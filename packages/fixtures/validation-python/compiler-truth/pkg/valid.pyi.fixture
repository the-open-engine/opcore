from collections.abc import Callable
from typing import Protocol, overload


class SupportsCall(Protocol):
    def __call__(
        self,
        value: int,
        /,
        *,
        transform: Callable[[int], str] = ...,
    ) -> str: ...


@overload
def convert(value: int) -> str: ...
@overload
def convert(value: str) -> bytes: ...
