{
  "name": "@the-open-engine/lattice-cli",
  "version": "0.1.0-alpha.0",
  "description": "Local code intelligence, safe edits, and pre-write validation for coding agents.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./descriptors/lattice.managed-tool.json": "./dist/descriptors/lattice.managed-tool.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "code-intelligence",
    "coding-agents",
    "static-analysis",
    "codemods",
    "typescript",
    "rust",
    "cli",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "lattice": "dist/index.js"
  },
  "dependencies": {
    "@the-open-engine/lattice-edit": "0.1.0-alpha.0",
    "@the-open-engine/lattice-contracts": "0.1.0-alpha.0",
    "@the-open-engine/lattice-graph": "0.1.0-alpha.0",
    "@the-open-engine/lattice-validation": "0.1.0-alpha.0",
    "@the-open-engine/lattice-validation-rust": "0.1.0-alpha.0",
    "@the-open-engine/lattice-validation-typescript": "0.1.0-alpha.0",
    "ts-morph": "^28.0.0"
  },
  "scripts": {
    "build": "tsc -b && node ../../scripts/write-cli-descriptor.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-open-engine/lattice.git",
    "directory": "packages/cli"
  }
}
