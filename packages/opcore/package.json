{
  "name": "@the-open-engine/opcore",
  "version": "0.1.0-alpha.0",
  "description": "Opcore CLI for read-only scans, setup guidance, validation gates, and metric deltas.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./descriptors/opcore.managed-tool.json": "./dist/descriptors/opcore.managed-tool.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "code-intelligence",
    "coding-agents",
    "robustness",
    "validation",
    "cli",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "opcore": "dist/index.js"
  },
  "dependencies": {
    "@the-open-engine/opcore-asp-provider": "0.1.0-alpha.0",
    "@the-open-engine/opcore-edit": "0.1.0-alpha.0",
    "@the-open-engine/opcore-contracts": "0.1.0-alpha.0",
    "@the-open-engine/opcore-graph": "0.1.0-alpha.0",
    "@the-open-engine/opcore-validation": "0.1.0-alpha.0",
    "@the-open-engine/opcore-validation-clone": "0.1.0-alpha.0",
    "@the-open-engine/opcore-validation-python": "0.1.0-alpha.0",
    "@the-open-engine/opcore-validation-rust": "0.1.0-alpha.0",
    "@the-open-engine/opcore-validation-typescript": "0.1.0-alpha.0",
    "ts-morph": "^28.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-open-engine/opcore.git",
    "directory": "packages/opcore"
  },
  "scripts": {
    "build": "tsc -b && node ../../scripts/write-cli-descriptor.mjs"
  }
}
